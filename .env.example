# Server port. Railway sets PORT automatically.
PORT=3000

# Product data storage directory.
# On Railway, set this to the mounted Volume path, for example /data.
DATA_DIR="./data"

# Default admin password is 666. Set this on Railway if you want to change it later.
ADMIN_PASSWORD="666"

# Optional: set a long random string in production so admin cookies stay signed safely.
SESSION_SECRET="change-this-before-production"
